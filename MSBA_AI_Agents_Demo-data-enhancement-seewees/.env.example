# =============================================================
# REQUIRED — OpenAI API
# =============================================================
# Get your key at https://platform.openai.com/api-keys
# This project uses gpt-4.1-mini; ~$0.01 per pipeline run.
OPENAI_API_KEY=""

# =============================================================
# OPTIONAL — Weather (Open-Meteo, no key needed)
# Defaults to Newark, NJ (the SeeWeeS warehouse origin).
# Per-corridor weather overrides this in the actual pipeline;
# these values only matter for legacy single-point fallback.
# =============================================================
WEATHER_LAT="40.7282"
WEATHER_LON="-74.0776"
WEATHER_TZ="America/New_York"

# =============================================================
# OPTIONAL — Email delivery (SMTP)
# Leave blank to skip email; report still saves to outputs/.
# Tested with Zoho and Gmail (use an app password, not your login).
# =============================================================
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=465
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# REPORT_EMAIL_TO=ops-director@example.com

# =============================================================
# OPTIONAL — LangSmith observability
# Free at https://smith.langchain.com — highly recommended for
# debugging multi-agent flows. Pipeline runs without it.
# =============================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=seewees-enhancement
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
